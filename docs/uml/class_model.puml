}

class ChannelFusionService {
  +setChannel(channel)
  +applyRecipe(recipe): ImageFrame
  +fuse(channels): ImageFrame
}

class DyeLibraryService {
  +listDyes(): vector<DyeProfile>
  +saveDye(profile)
  +removeDye(id)
}

class DyeLibrary {
  +defaultDyes(): vector<DyeProfile>
  +fallbackDye(): DyeProfile
  +findByName(dyes, name): DyeProfile
  +indexAtSelection(selection, dyeCount): size_t
  +upsertByName(dyes, dye): DyeLibraryUpdateResult
  +deleteAt(dyes, index): DyeLibraryDeleteResult
}

class FluorescenceChannelFactory {
  +createFromFrame(dye, frame, index): FluorescenceChannel
}

class FluorescenceChannelListActions {
  +addCurrentFrame(channels, frame, dye): FluorescenceChannelListActionResult
  +clear(channels): FluorescenceChannelListActionResult
}

class FluorescenceChannelSettings {
  +defaults(visible): FluorescenceChannelDisplaySettings
  +indexAtSelection(selection, channelCount): size_t
  +fromLevels(visible, blackLevel, whiteLevel): FluorescenceChannelDisplaySettings
  +fromChannel(channel): FluorescenceChannelDisplaySettings
  +apply(channel, settings)
}

class FluorescenceChannelUpdater {
  +apply(channels, selection, visible, blackLevel, whiteLevel): FluorescenceChannelUpdateResult
}

class StitchingService {
  +addTile(frame, positionHint)
  +createJob(project): ProcessingJob
  +alignTiles(): StitchingProject
  +renderMosaic(): ImageFrame
}

class EdfService {
  +addSlice(frame, zIndex)
  +createJob(stack): ProcessingJob
  +alignStack(): ImageStack
  +compose(): EdfResult
}

class ProcessingQueue {
  +submit(job): ProcessingJob
  +cancel(jobId)
